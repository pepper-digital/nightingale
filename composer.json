{
    "name": "pepperdigital/nightingale",
    "description": "Per-page accessibility auditing for Craft CMS editors",
    "type": "craft-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Pepper Digital",
            "homepage": "https://pepper.digital"
        }
    ],
    "require": {
        "craftcms/cms": "^5.0.0"
    },
    "require-dev": {
        "craftcms/ecs": "*",
        "craftcms/phpstan": "*",
        "phpstan/phpstan": "*",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "pepperdigital\\nightingale\\": "src/"
        }
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --ansi --fix",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "class": "pepperdigital\\nightingale\\Nightingale",
        "handle": "nightingale",
        "name": "Nightingale",
        "craftcms": {
            "name": "Nightingale",
            "developer": "Pepper Digital",
            "developerUrl": "https://pepper.digital",
            "description": "Per-page accessibility auditing for Craft CMS editors"
        }
    }
}
